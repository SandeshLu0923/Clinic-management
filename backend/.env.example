# MongoDB Configuration
MONGODB_URI=mongodb+srv://<db_user>:<db_password>@<cluster>.mongodb.net/clinic-management

# JWT Configuration
JWT_SECRET=replace_with_a_strong_secret
JWT_EXPIRE=7d

# CORS Configuration
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=https://clinic-management-frontend.vercel.app,https://*.vercel.app,https://clinic-management-frontend.netlify.app

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Server Configuration
PORT=5000
NODE_ENV=development
ALLOW_START_WITHOUT_DB=false

# SMS Configuration
# Set SMS_PROVIDER=twilio to enable SMS delivery, otherwise notifications are skipped gracefully.
SMS_PROVIDER=console
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

